# ============================================================
#  Autonomous Code Review & Debugging Agent — Environment Vars
# ============================================================

# --- LLM API Keys (at least one is required) ----------------

# Google Gemini API key (primary)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API key (optional — for GPT-4 fallback)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API key (optional — for Claude fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Sandbox -------------------------------------------------

# E2B sandbox API key (required for sandboxed test execution)
E2B_API_KEY=your_e2b_api_key_here

# --- GitHub --------------------------------------------------

# GitHub Personal Access Token (optional — needed for private repos)
GITHUB_TOKEN=your_github_token_here

# --- Model Configuration ------------------------------------

# Default LLM provider: "gemini" | "openai" | "anthropic"
LLM_PROVIDER=gemini

# Default model name (e.g., gemini-2.0-flash, gpt-4, claude-3-5-sonnet)
LLM_MODEL=gemini-2.0-flash
